{
  "name": "mui-language-picker",
  "version": "2.7.1",
  "description": "Material UI language picker",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist coverage",
    "data": "node src/langPicker/getJsonData.js",
    "index": "node src/langPicker/makeIndex2.js",
    "build": "npm test && tsc",
    "format": "prettier --write .",
    "lint": "eslint src",
    "pretest": "npm run lint",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sillsdev/mui-language-picker.git"
  },
  "keywords": [
    "language",
    "bcp47",
    "font",
    "script"
  ],
  "author": "Greg Trihus <greg_trihus@sil.org>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sillsdev/mui-language-picker/issues"
  },
  "homepage": "https://github.com/sillsdev/mui-language-picker#readme",
  "devDependencies": {
    "@babel/cli": "^7.24.7",
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "axios": "^1.18.0",
    "copyfiles": "^2.4.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.5",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "write": "^2.0.0"
  },
  "peerdependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "dependencies": {
    "lodash": "^4.18.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js"
    ],
    "transform": {
      "\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "testRegex": "(/__tests__/.*|.*\\.test)\\.(ts|tsx)$"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "volta": {
    "node": "22.19.0"
  }
}
